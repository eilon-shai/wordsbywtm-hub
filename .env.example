# Words That Matter — wordsbywtm-hub env
# Copy to .env.development.local and fill in. For local E2E set ENABLE_MOCK_PAYMENT=true.
#
# This file is the LOCAL-DEV template (sandbox + mock defaults). For the full
# inventory of every var configured in Vercel (prod + preview, secrets key-only),
# see docs/ENV.md.

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_URL=http://localhost:3005

# ── Local dev / test flags ───────────────────────────────────────────────────
ENABLE_MOCK_PAYMENT=true          # bypass real Paddle verification for local E2E
DISABLE_EMAIL=true                # don't send real email locally
DISABLE_TRIBUTE_AUDIO=true        # skip ElevenLabs audio locally (optional)
# NEXT_PUBLIC_ENABLE_MOCK_TESTIMONIALS=true
# NEXT_PUBLIC_DISABLE_ANALYTICS=true

# ── Database — Neon Postgres (shared with other WTM apps) ─────────────────────
# DATABASE_URL is the one the app reads. Neon also provisions a POSTGRES_*/PG*
# family (see docs/ENV.md) — not required for local dev.
DATABASE_URL=

# ── Redis — Upstash (locks, rate limiting, txn->collection mapping) ───────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Encryption key for contributor PII at rest. MUST match any app sharing the DB.
# In mock mode the library falls back to a fixed test key, so this is only
# strictly required for non-mock / production runs.
REDIS_FORM_ENCRYPTION_KEY=

# ── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
# Synthesis model override. Prod defaults to claude-opus-4-8 (strongest writer).
# Locally use the cheapest model to save cost:
SYNTHESIS_MODEL=claude-haiku-4-5
# Only needed if DISABLE_TRIBUTE_AUDIO is not true:
ELEVENLABS_API_KEY=

# ── Email — Resend (only if DISABLE_EMAIL is not true) ────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL_MEMORIAL=memorial@wordsbywtm.com
RESEND_FROM_EMAIL_WEDDING=wedding@wordsbywtm.com
RESEND_FROM_EMAIL_RETIREMENT=retirement@wordsbywtm.com
RESEND_FROM_EMAIL_ANNIVERSARY=anniversary@wordsbywtm.com

# ── Paddle — sandbox (local/preview). Prod uses the non-_SANDBOX keys. ─────────
PADDLE_ENVIRONMENT=sandbox
NEXT_PUBLIC_PADDLE_ENVIRONMENT=sandbox
PADDLE_API_KEY_SANDBOX=
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN_SANDBOX=
PADDLE_WEBHOOK_SECRET_SANDBOX=

# Per-occasion: PADDLE_PRODUCT_ID_* (server, webhook routing) +
# NEXT_PUBLIC_PADDLE_PRICE_ID_*_SANDBOX (client checkout). Memorial sandbox
# values are founder-created and safe to commit; fill the rest from Paddle sandbox.
PADDLE_PRODUCT_ID_MEMORIAL=pro_01kv1g5d6c4b3wcr74jswnnspa
NEXT_PUBLIC_PADDLE_PRICE_ID_MEMORIAL_SANDBOX=pri_01kv1g6pw7wje6q9f2g3wzx9zr
PADDLE_PRODUCT_ID_WEDDING=
NEXT_PUBLIC_PADDLE_PRICE_ID_WEDDING_SANDBOX=
PADDLE_PRODUCT_ID_RETIREMENT=
NEXT_PUBLIC_PADDLE_PRICE_ID_RETIREMENT_SANDBOX=
PADDLE_PRODUCT_ID_ANNIVERSARY=
NEXT_PUBLIC_PADDLE_PRICE_ID_ANNIVERSARY_SANDBOX=

# ── Support console (/support Basic-Auth) + cron bearer ───────────────────────
SUPPORT_PASSWORD=
CRON_SECRET=
CONTRIBUTION_HASH_SECRET=

# ── Build — GitHub Packages auth for @eilon-shai/venture-core ─────────────────
# Required for `npm install` and the Vercel build.
NPM_TOKEN=

# ── Analytics (PRODUCTION ONLY — leave unset locally) ─────────────────────────
# Public ids that ship in the browser bundle. See docs/ENV.md. Not needed for dev.
# NEXT_PUBLIC_GA4_MEASUREMENT_ID=
# NEXT_PUBLIC_CLARITY_PROJECT_ID=
# NEXT_PUBLIC_GOOGLE_ADS_TAG_ID=
# NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_LABEL=

# ── Under-construction gate (production) ──────────────────────────────────────
# UNDER_CONSTRUCTION=false
# CONSTRUCTION_BYPASS_TOKEN=
