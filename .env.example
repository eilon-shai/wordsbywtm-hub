# Words That Matter — collection app env
# Copy to .env.development.local and fill in. For local E2E set ENABLE_MOCK_PAYMENT=true.

# App
NEXT_PUBLIC_URL=http://localhost:3005

# Mock payment bypass for local E2E (skips real Paddle verification).
ENABLE_MOCK_PAYMENT=true
# Skip sending real emails locally.
DISABLE_EMAIL=true

# Database (shared Neon Postgres — SAME value as tributewords-app).
DATABASE_URL=

# Encryption key for contributor PII at rest. MUST match any app sharing the DB.
# (In mock mode the library falls back to a fixed test key, so this is only
#  strictly required for production / non-mock runs.)
REDIS_FORM_ENCRYPTION_KEY=

# Upstash Redis (locks, rate limiting, txn->collection mapping).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Anthropic (synthesis).
ANTHROPIC_API_KEY=

# Resend (magic-link + deliverable emails). Not needed if DISABLE_EMAIL=true.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Words That Matter <memorial@wordsbywtm.com>

# Paddle — sandbox for now.
PADDLE_ENVIRONMENT=sandbox
NEXT_PUBLIC_PADDLE_ENVIRONMENT=sandbox
PADDLE_API_KEY_SANDBOX=
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN_SANDBOX=
PADDLE_WEBHOOK_SECRET_SANDBOX=

# Memorial occasion — Paddle sandbox product + price (founder-created).
PADDLE_PRODUCT_ID_MEMORIAL=pro_01kv1g5d6c4b3wcr74jswnnspa
NEXT_PUBLIC_PADDLE_PRICE_ID_MEMORIAL_SANDBOX=pri_01kv1g6pw7wje6q9f2g3wzx9zr

# Production Paddle (placeholders — fill when live prices exist).
PADDLE_API_KEY=
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
NEXT_PUBLIC_PADDLE_PRICE_ID_MEMORIAL=
